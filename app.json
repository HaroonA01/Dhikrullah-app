{
  "expo": {
    "name": "Dhikrullah",
    "slug": "dhikrullah",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "dhikrullah",
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Dhikrullah uses your location to calculate accurate prayer times."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#A78BFA",
          "sounds": [
            "./assets/sounds/chime.wav",
            "./assets/sounds/bell.wav",
            "./assets/sounds/glow.wav",
            "./assets/sounds/tap.wav"
          ]
        }
      ],
      "expo-audio",
      "expo-asset"
    ],
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#14241B"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.dhikrullah.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Dhikrullah uses your location to calculate accurate prayer times.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "package": "app.dhikrullah.app",
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "router": {}
    }
  }
}
